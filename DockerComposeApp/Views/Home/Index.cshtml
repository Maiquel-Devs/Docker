@model IEnumerable<DockerComposeApp.Models.Produto>

@{
    ViewData["Title"] = "CRUD Docker";
}

<div class="container mt-4">
    <h2>Cadastro Rápido (SQL Server no Docker)</h2>

    <!-- Formulário simples -->
    <form asp-action="Criar" method="post" class="row g-3 my-3">
        <div class="col-md-5">
            <input type="text" name="Nome" class="form-control" placeholder="Nome do item" required />
        </div>
        <div class="col-md-4">
            <input type="number" step="0.01" name="Preco" class="form-control" placeholder="Preço" required />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-success w-100">Salvar no Banco</button>
        </div>
    </form>

    <hr />

    <!-- Tabela de listagem -->
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Preço</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nome</td>
                <td>R$ @item.Preco</td>
            </tr>
        }
        </tbody>
    </table>
</div>